<Window
    x:Class="IfcViewer.UI.IfcViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:IfcViewer"
    xmlns:ui="clr-namespace:IfcViewer.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="IFC Viewer"
    Width="1000"
    Height="700"
    MinWidth="800"
    MinHeight="500"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove"
    mc:Ignorable="av">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="PrimaryBackgroundBrush"   Color="#FF1F1F1F" />
                    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#FF292929" />
                    <SolidColorBrush x:Key="BorderBrush"              Color="#FF444444" />
                    <SolidColorBrush x:Key="ForegroundBrush"          Color="#EEEEEE"   />
                    <SolidColorBrush x:Key="HighlightBrush"           Color="#FF505050" />
                    <SolidColorBrush x:Key="TextHighlightBrush"       Color="#FF0078D7" />
                    <SolidColorBrush x:Key="ScrollBarThumbBrush"      Color="#FF808080" />
                    <SolidColorBrush x:Key="IconBrush"                Color="#FFAAAAAA" />
                    <SolidColorBrush x:Key="IconForegroundBrush"      Color="#FF888888" />
                    <SolidColorBrush x:Key="IconHoverBrush"           Color="#FF70BABC" />
                    <SolidColorBrush x:Key="SelectionHoverBrush"      Color="#FF606060" />
                    <Color x:Key="ForegroundColor">#EEEEEE</Color>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/IfcViewer;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Outer glassy border -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2" />
            </Border.Effect>
        </Border>

        <!-- Content container -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            CornerRadius="10">
            <Grid x:Name="MainContentGrid" PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />  <!-- Title bar -->
                    <RowDefinition Height="Auto" /> <!-- Toolbar -->
                    <RowDefinition Height="*" />    <!-- Viewer area -->
                </Grid.RowDefinitions>

                <!-- ─────────────── Row 0: Title bar ─────────────── -->
                <ui:TitleBar
                    Grid.Row="0"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded" />

                <!-- Theme toggle -->
                <ToggleButton
                    x:Name="ThemeToggleButton"
                    Grid.Row="0"
                    Width="28" Height="15.5"
                    Margin="0,0,70,0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="ToggleTheme_Click"
                    IsChecked="True"
                    ToolTip="Toggle Theme">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Grid Background="Transparent">
                                <materialDesign:PackIcon
                                    x:Name="ThemeToggleIcon"
                                    Width="30" Height="30"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Foreground="{DynamicResource IconBrush}"
                                    Kind="ToggleSwitchOffOutline" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOffOutline" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOutline" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- ─────────────── Row 1: Toolbar ─────────────── -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal">

                        <!-- Add IFC -->
                        <Button x:Name="AddIfcButton"
                                Click="AddIfc_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32"
                                Margin="0,0,6,0"
                                ToolTip="Add IFC file">
                            <materialDesign:PackIcon Kind="FolderPlusOutline" Width="20" Height="20"/>
                        </Button>

                        <!-- Remove IFC -->
                        <Button x:Name="RemoveIfcButton"
                                Click="RemoveIfc_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32"
                                Margin="0,0,6,0"
                                ToolTip="Remove selected IFC">
                            <materialDesign:PackIcon Kind="FolderRemoveOutline" Width="20" Height="20"/>
                        </Button>

                        <Separator Width="1" Margin="4,4" Background="{DynamicResource BorderBrush}"/>

                        <!-- Sync Revit view (placeholder, enabled in Stage 3) -->
                        <Button x:Name="SyncRevitButton"
                                Click="SyncRevit_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32"
                                Margin="0,0,6,0"
                                ToolTip="Sync active Revit 3D view">
                            <materialDesign:PackIcon Kind="Sync" Width="20" Height="20"/>
                        </Button>

                        <Separator Width="1" Margin="4,4" Background="{DynamicResource BorderBrush}"/>

                        <!-- Reset camera (placeholder, enabled in Stage 1) -->
                        <Button x:Name="ResetCameraButton"
                                Click="ResetCamera_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32"
                                Margin="0,0,6,0"
                                ToolTip="Reset camera">
                            <materialDesign:PackIcon Kind="CameraFlip" Width="20" Height="20"/>
                        </Button>

                    </StackPanel>
                </Border>

                <!-- ─────────────── Row 2: Main viewer layout ─────────────── -->
                <Grid Grid.Row="2" Margin="0">
                    <Grid.ColumnDefinitions>
                        <!-- Left panel: IFC list + controls -->
                        <ColumnDefinition Width="200" MinWidth="150" MaxWidth="350"/>
                        <!-- Splitter -->
                        <ColumnDefinition Width="4"/>
                        <!-- Viewport area -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Left panel ── -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Panel header -->
                            <TextBlock Grid.Row="0"
                                       Text="Loaded Models"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource IconBrush}"
                                       Margin="8,8,8,4"
                                       TextTransform="Uppercase"/>

                            <!-- IFC / Revit model list -->
                            <ListBox x:Name="ModelListBox"
                                     Grid.Row="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     SelectionMode="Single"
                                     Margin="4,0,4,4"/>

                            <!-- Opacity sliders (placeholder, wired in Stage 2+) -->
                            <StackPanel Grid.Row="2" Margin="8,4,8,8">
                                <TextBlock Text="IFC Opacity"
                                           Foreground="{DynamicResource IconBrush}"
                                           FontSize="10"
                                           Margin="0,0,0,2"/>
                                <Slider x:Name="IfcOpacitySlider"
                                        Minimum="0" Maximum="1" Value="1"
                                        SmallChange="0.05" LargeChange="0.1"
                                        Foreground="{DynamicResource TextHighlightBrush}"
                                        ValueChanged="IfcOpacity_ValueChanged"/>

                                <TextBlock Text="Revit Opacity"
                                           Foreground="{DynamicResource IconBrush}"
                                           FontSize="10"
                                           Margin="0,8,0,2"/>
                                <Slider x:Name="RevitOpacitySlider"
                                        Minimum="0" Maximum="1" Value="1"
                                        SmallChange="0.05" LargeChange="0.1"
                                        Foreground="{DynamicResource TextHighlightBrush}"
                                        ValueChanged="RevitOpacity_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ── Grid splitter ── -->
                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BorderBrush}"
                                  ShowsPreview="False"/>

                    <!-- ── Viewport column: Stage 0 placeholder, replaced in Stage 1 ── -->
                    <Grid Grid.Column="2" x:Name="ViewportContainer">
                        <!-- Stage 0 placeholder label -->
                        <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                x:Name="ViewerPlaceholder">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon
                                    Kind="Video3d"
                                    Width="64" Height="64"
                                    HorizontalAlignment="Center"
                                    Foreground="{DynamicResource IconBrush}"
                                    Opacity="0.4"/>
                                <TextBlock Text="Viewer Ready"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource IconBrush}"
                                           Opacity="0.5"
                                           HorizontalAlignment="Center"
                                           Margin="0,12,0,4"/>
                                <TextBlock Text="GPU viewport will be initialized in Stage 1"
                                           FontSize="11"
                                           Foreground="{DynamicResource IconBrush}"
                                           Opacity="0.35"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Resize edges (same as template) ── -->
        <Border x:Name="LeftEdge" Width="5" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown" />
        <Border x:Name="RightEdge" Width="9" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseLeftButtonDown="RightEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomEdge" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNS" Panel.ZIndex="3000"
                MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomLeftCorner" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNESW" Panel.ZIndex="3000"
                MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown" />
        <Border x:Name="BottomRightCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNWSE" Panel.ZIndex="3000"
                MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown" />
    </Grid>
</Window>
