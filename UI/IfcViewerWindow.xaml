<Window
    x:Class="IfcViewer.UI.IfcViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:IfcViewer"
    xmlns:ui="clr-namespace:IfcViewer.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="IFC Viewer"
    Width="1000"
    Height="700"
    MinWidth="800"
    MinHeight="500"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    MouseMove="Window_MouseMove"
    Closed="Window_Closed"
    mc:Ignorable="av">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="PrimaryBackgroundBrush"   Color="#FF1F1F1F" />
                    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#FF292929" />
                    <SolidColorBrush x:Key="BorderBrush"              Color="#FF444444" />
                    <SolidColorBrush x:Key="ForegroundBrush"          Color="#EEEEEE"   />
                    <SolidColorBrush x:Key="HighlightBrush"           Color="#FF505050" />
                    <SolidColorBrush x:Key="TextHighlightBrush"       Color="#FF0078D7" />
                    <SolidColorBrush x:Key="ScrollBarThumbBrush"      Color="#FF808080" />
                    <SolidColorBrush x:Key="IconBrush"                Color="#FFAAAAAA" />
                    <SolidColorBrush x:Key="IconForegroundBrush"      Color="#FF888888" />
                    <SolidColorBrush x:Key="IconHoverBrush"           Color="#FF70BABC" />
                    <SolidColorBrush x:Key="SelectionHoverBrush"      Color="#FF606060" />
                    <Color x:Key="ForegroundColor">#EEEEEE</Color>
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/IfcViewer;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Outer glassy border -->
        <Border
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            ClipToBounds="True"
            CornerRadius="10"
            Opacity="0.7"
            SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2" />
            </Border.Effect>
        </Border>

        <!-- Content container -->
        <Border
            Margin="2"
            Background="{DynamicResource PrimaryBackgroundBrush}"
            CornerRadius="10">
            <Grid x:Name="MainContentGrid" PreviewMouseDown="Window_PreviewMouseDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ── Title bar ── -->
                <ui:TitleBar
                    Grid.Row="0"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Loaded="TitleBar_Loaded" />

                <ToggleButton
                    x:Name="ThemeToggleButton"
                    Grid.Row="0"
                    Width="28" Height="15.5"
                    Margin="0,0,70,0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="ToggleTheme_Click"
                    IsChecked="True"
                    ToolTip="Toggle Theme">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Grid Background="Transparent">
                                <materialDesign:PackIcon
                                    x:Name="ThemeToggleIcon"
                                    Width="30" Height="30"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Foreground="{DynamicResource IconBrush}"
                                    Kind="ToggleSwitchOffOutline" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOffOutline" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="ThemeToggleIcon" Property="Kind" Value="ToggleSwitchOutline" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>

                <!-- ── Toolbar ── -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="AddIfcButton"
                                Click="AddIfc_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32" Margin="0,0,6,0"
                                ToolTip="Add IFC file">
                            <materialDesign:PackIcon Kind="FolderPlusOutline" Width="20" Height="20"/>
                        </Button>
                        <Button x:Name="RemoveIfcButton"
                                Click="RemoveIfc_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32" Margin="0,0,6,0"
                                ToolTip="Remove selected IFC">
                            <materialDesign:PackIcon Kind="FolderRemoveOutline" Width="20" Height="20"/>
                        </Button>
                        <Separator Width="1" Margin="4,4" Background="{DynamicResource BorderBrush}"/>
                        <Button x:Name="SyncRevitButton"
                                Click="SyncRevit_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32" Margin="0,0,6,0"
                                ToolTip="Sync active Revit 3D view (full export)">
                            <materialDesign:PackIcon Kind="Sync" Width="20" Height="20"/>
                        </Button>
                        <!-- Auto-sync toggle: watches DocumentChanged and incrementally updates dirty elements -->
                        <ToggleButton x:Name="AutoSyncToggle"
                                      Checked="AutoSync_Checked"
                                      Unchecked="AutoSync_Unchecked"
                                      Width="32" Height="32" Margin="0,0,6,0"
                                      ToolTip="Auto-sync Revit geometry — updates incrementally on every model change"
                                      Style="{StaticResource CustomActionToggleButtonStyle}">
                            <materialDesign:PackIcon Kind="SyncAlert" Width="20" Height="20"/>
                        </ToggleButton>
                        <Separator Width="1" Margin="4,4" Background="{DynamicResource BorderBrush}"/>
                        <Button x:Name="ResetCameraButton"
                                Click="ResetCamera_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32" Margin="0,0,6,0"
                                ToolTip="Reset camera to default view">
                            <materialDesign:PackIcon Kind="CameraFlip" Width="20" Height="20"/>
                        </Button>
                        <ToggleButton x:Name="WireframeToggle"
                                      Checked="Wireframe_Checked"
                                      Unchecked="Wireframe_Unchecked"
                                      Width="32" Height="32" Margin="0,0,6,0"
                                      ToolTip="Toggle wireframe overlay"
                                      Style="{StaticResource CustomActionToggleButtonStyle}">
                            <materialDesign:PackIcon Kind="Cube" Width="20" Height="20"/>
                        </ToggleButton>
                        <Separator Width="1" Margin="4,4" Background="{DynamicResource BorderBrush}"/>
                        <!-- First-person walk mode -->
                        <ToggleButton x:Name="WalkModeToggle"
                                      Checked="WalkMode_Checked"
                                      Unchecked="WalkMode_Unchecked"
                                      Width="32" Height="32" Margin="0,0,6,0"
                                      ToolTip="First-person walk mode (WASD / arrows, right-drag to look)"
                                      Style="{StaticResource CustomActionToggleButtonStyle}">
                            <materialDesign:PackIcon Kind="Walk" Width="20" Height="20"/>
                        </ToggleButton>
                        <!-- Section plane -->
                        <ToggleButton x:Name="SectionPlaneToggle"
                                      Checked="SectionPlane_Checked"
                                      Unchecked="SectionPlane_Unchecked"
                                      Width="32" Height="32" Margin="0,0,6,0"
                                      ToolTip="Toggle section plane"
                                      Style="{StaticResource CustomActionToggleButtonStyle}">
                            <materialDesign:PackIcon Kind="Scissors" Width="20" Height="20"/>
                        </ToggleButton>
                        <Separator Width="1" Margin="4,4" Background="{DynamicResource BorderBrush}"/>
                        <!-- Settings -->
                        <Button x:Name="SettingsButton"
                                Click="Settings_Click"
                                Style="{StaticResource CustomActionButtonStyle}"
                                Width="32" Height="32" Margin="0,0,0,0"
                                ToolTip="Viewer settings">
                            <materialDesign:PackIcon Kind="Cog" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ── Main layout ── -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" MinWidth="150" MaxWidth="350"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="220" MinWidth="160" MaxWidth="400"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left panel -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,1,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="LOADED MODELS"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource IconBrush}"
                                       Margin="8,8,8,4"/>
                            <ListBox x:Name="ModelListBox"
                                     Grid.Row="1"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     SelectionMode="Single"
                                     Margin="4,0,4,4"/>
                            <StackPanel Grid.Row="2" Margin="8,4,8,8">
                                <TextBlock Text="IFC Opacity"
                                           Foreground="{DynamicResource IconBrush}"
                                           FontSize="10" Margin="0,0,0,2"/>
                                <Slider x:Name="IfcOpacitySlider"
                                        Minimum="0" Maximum="1" Value="1"
                                        SmallChange="0.05" LargeChange="0.1"
                                        Foreground="{DynamicResource TextHighlightBrush}"
                                        ValueChanged="IfcOpacity_ValueChanged"/>
                                <TextBlock Text="Revit Opacity"
                                           Foreground="{DynamicResource IconBrush}"
                                           FontSize="10" Margin="0,8,0,2"/>
                                <Slider x:Name="RevitOpacitySlider"
                                        Minimum="0" Maximum="1" Value="1"
                                        SmallChange="0.05" LargeChange="0.1"
                                        Foreground="{DynamicResource TextHighlightBrush}"
                                        ValueChanged="RevitOpacity_ValueChanged"/>

                                <!-- ── Section Plane ── -->
                                <Separator Margin="0,10,0,6" Background="{DynamicResource BorderBrush}"/>
                                <TextBlock Text="SECTION PLANE"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource IconBrush}"
                                           Margin="0,0,0,6"/>

                                <!-- Axis selector -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <RadioButton x:Name="SectionAxisX"
                                                 Content="X" GroupName="SectionAxis"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 Margin="0,0,8,0"
                                                 Checked="SectionAxis_Changed"/>
                                    <RadioButton x:Name="SectionAxisY"
                                                 Content="Y" GroupName="SectionAxis"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 Margin="0,0,8,0"
                                                 Checked="SectionAxis_Changed"/>
                                    <RadioButton x:Name="SectionAxisZ"
                                                 Content="Z" GroupName="SectionAxis"
                                                 IsChecked="True"
                                                 Foreground="{DynamicResource ForegroundBrush}"
                                                 Checked="SectionAxis_Changed"/>
                                </StackPanel>

                                <!-- Offset label + value -->
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Offset (m)"
                                               Foreground="{DynamicResource IconBrush}"
                                               FontSize="10"/>
                                    <TextBlock x:Name="SectionOffsetLabel"
                                               Grid.Column="1" Text="0.00"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               FontSize="10"/>
                                </Grid>
                                <Slider x:Name="SectionOffsetSlider"
                                        Minimum="-50" Maximum="50" Value="0"
                                        SmallChange="0.1" LargeChange="1"
                                        Foreground="{DynamicResource TextHighlightBrush}"
                                        ValueChanged="SectionOffset_ValueChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Left splitter -->
                    <GridSplitter Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BorderBrush}"
                                  ShowsPreview="False"/>

                    <!-- Right splitter -->
                    <GridSplitter Grid.Column="3"
                                  HorizontalAlignment="Stretch"
                                  Background="{DynamicResource BorderBrush}"
                                  ShowsPreview="False"/>

                    <!-- Viewport host — Viewport3DX injected in code-behind after
                         assembly resolver fires; no Helix types in XAML. -->
                    <Grid Grid.Column="2" x:Name="ViewportContainer" ClipToBounds="True"
                          Background="#FF1A1A1A">

                        <!-- IFC file-change notification banner -->
                        <Border x:Name="ReloadBanner"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Background="#CC1F1F1F"
                                BorderBrush="#FF444444" BorderThickness="1"
                                CornerRadius="4" Padding="10,6" Margin="0,8,0,0"
                                Panel.ZIndex="20" IsHitTestVisible="True">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileAlert" Width="16" Height="16"
                                                         Foreground="#FFAAAAAA"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0"/>
                                <TextBlock x:Name="ReloadBannerText"
                                           Foreground="#FFEEEEEE" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <Button x:Name="ReloadBannerButton"
                                        Content="Reload"
                                        Style="{StaticResource CustomActionButtonStyle}"
                                        Height="22" Padding="8,0"
                                        Click="ReloadBannerButton_Click"/>
                                <Button Content="✕"
                                        Style="{StaticResource CustomActionButtonStyle}"
                                        Height="22" Width="22" Margin="4,0,0,0"
                                        Click="ReloadBannerDismiss_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Status overlay -->
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="#66000000"
                                CornerRadius="4"
                                Padding="6,2"
                                Margin="0,0,6,6"
                                IsHitTestVisible="False"
                                Panel.ZIndex="10">
                            <TextBlock x:Name="StatusBar"
                                       Text="Initializing GPU viewport…"
                                       Foreground="#FF70BABC"
                                       FontSize="10"/>
                        </Border>
                    </Grid>

                    <!-- ── Properties panel ── -->
                    <Border Grid.Column="4"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: panel header -->
                            <TextBlock Grid.Row="0"
                                       Text="PROPERTIES"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource IconBrush}"
                                       Margin="8,8,8,4"/>

                            <!-- Row 1: empty hint OR element identity + tab bar -->
                            <StackPanel Grid.Row="1" Margin="8,0,8,0">

                                <TextBlock x:Name="PropEmptyHint"
                                           Text="Click an element in the viewport to view its properties."
                                           Foreground="{DynamicResource IconBrush}"
                                           FontSize="10"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>

                                <StackPanel x:Name="PropContent" Visibility="Collapsed">
                                    <TextBlock x:Name="PropName"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource ForegroundBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,2"/>
                                    <TextBlock x:Name="PropType"
                                               FontSize="10"
                                               Foreground="{DynamicResource IconBrush}"
                                               Margin="0,0,0,2"/>
                                    <TextBlock x:Name="PropGlobalId"
                                               FontSize="9"
                                               Foreground="{DynamicResource IconBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6"/>
                                    <Separator Background="{DynamicResource BorderBrush}"
                                               Margin="-8,0,-8,0"/>
                                    <!-- Tab bar — tabs + overflow chevron button -->
                                    <Grid Margin="-8,0,-8,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Tabs; scrollable but bar hidden — BringIntoView handles navigation -->
                                        <ScrollViewer x:Name="PropTabScroll"
                                                      Grid.Column="0"
                                                      HorizontalScrollBarVisibility="Hidden"
                                                      VerticalScrollBarVisibility="Disabled">
                                            <StackPanel x:Name="PropTabBar" Orientation="Horizontal"/>
                                        </ScrollViewer>

                                        <!-- Overflow chevron — opens the category dropdown -->
                                        <Border x:Name="PropTabOverflowBtn"
                                                Grid.Column="1"
                                                Width="26"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                VerticalAlignment="Stretch"
                                                ToolTip="All categories"
                                                MouseLeftButtonDown="PropTabOverflow_Click">
                                            <materialDesign:PackIcon Kind="ChevronDown"
                                                                     Width="14" Height="14"
                                                                     Foreground="{DynamicResource IconBrush}"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Dropdown listing all categories -->
                                        <Popup x:Name="PropTabOverflowPopup"
                                               Grid.Column="1"
                                               PlacementTarget="{Binding ElementName=PropTabOverflowBtn}"
                                               Placement="Bottom"
                                               StaysOpen="True"
                                               AllowsTransparency="True">
                                            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1">
                                                <ScrollViewer MaxHeight="240"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <StackPanel x:Name="PropTabOverflowPanel" MinWidth="160"/>
                                                </ScrollViewer>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                    <Separator Background="{DynamicResource BorderBrush}"
                                               Margin="-8,0,-8,0"/>
                                </StackPanel>

                            </StackPanel>

                            <!-- Row 2: scrollable property rows for the active tab -->
                            <ScrollViewer x:Name="PropTabContent"
                                          Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Visibility="Collapsed">
                                <StackPanel x:Name="PropPropsPanel" Margin="8,6,8,8"/>
                            </ScrollViewer>

                        </Grid>
                    </Border>

                </Grid>
            </Grid>
        </Border>

        <!-- Resize edges -->
        <Border x:Name="LeftEdge" Width="5" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseLeftButtonDown="LeftEdge_MouseLeftButtonDown" />
        <Border x:Name="RightEdge" Width="9" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Background="Transparent" Cursor="SizeWE" Panel.ZIndex="3000"
                MouseLeftButtonDown="RightEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomEdge" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNS" Panel.ZIndex="3000"
                MouseLeftButtonDown="BottomEdge_MouseLeftButtonDown" />
        <Border x:Name="BottomLeftCorner" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNESW" Panel.ZIndex="3000"
                MouseLeftButtonDown="BottomLeftCorner_MouseLeftButtonDown" />
        <Border x:Name="BottomRightCorner" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNWSE" Panel.ZIndex="3000"
                MouseLeftButtonDown="BottomRightCorner_MouseLeftButtonDown" />
    </Grid>
</Window>
