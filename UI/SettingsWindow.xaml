<Window
    x:Class="IfcViewer.UI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="Viewer Settings"
    Width="360"
    SizeToContent="Height"
    ResizeMode="NoResize"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    WindowStartupLocation="CenterOwner"
    ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="PrimaryBackgroundBrush"   Color="#FF1F1F1F" />
                    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#FF292929" />
                    <SolidColorBrush x:Key="BorderBrush"              Color="#FF444444" />
                    <SolidColorBrush x:Key="ForegroundBrush"          Color="#EEEEEE"   />
                    <SolidColorBrush x:Key="HighlightBrush"           Color="#FF505050" />
                    <SolidColorBrush x:Key="TextHighlightBrush"       Color="#FF0078D7" />
                    <SolidColorBrush x:Key="IconHoverBrush"           Color="#FF70BABC" />
                    <SolidColorBrush x:Key="IconBrush"                Color="#FFAAAAAA" />
                </ResourceDictionary>
                <ResourceDictionary Source="pack://application:,,,/IfcViewer;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent">
        <!-- Outer glassy border -->
        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="2"
                ClipToBounds="True"
                CornerRadius="10"
                Opacity="0.7"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2" />
            </Border.Effect>
        </Border>

        <!-- Content container -->
        <Border Margin="2"
                Background="{DynamicResource PrimaryBackgroundBrush}"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="44"/>
                </Grid.RowDefinitions>

                <!-- ── Title bar ── -->
                <Grid Grid.Row="0" Background="Transparent"
                      MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <TextBlock Text="VIEWER SETTINGS"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource IconBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                    <Button x:Name="CloseButton"
                            Width="28" Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,2,0"
                            Click="Close_Click"
                            Style="{StaticResource CustomActionButtonStyle}"
                            ToolTip="Close">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                    </Button>
                </Grid>

                <!-- ── Settings content ── -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="14,8,14,8">
                    <StackPanel>

                        <!-- ── Walk Mode ── -->
                        <TextBlock Text="WALK MODE"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource IconBrush}"
                                   Margin="0,4,0,8"/>

                        <!-- Walk speed -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Walk speed (m/s)"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="WalkSpeedLabel" Grid.Column="1"
                                       Text="5.0"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="WalkSpeedSlider"
                                Minimum="1" Maximum="30" Value="5"
                                SmallChange="0.5" LargeChange="2"
                                Foreground="{DynamicResource TextHighlightBrush}"
                                Margin="0,0,0,12"
                                ValueChanged="WalkSpeed_ValueChanged"/>

                        <!-- Sprint multiplier -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Sprint multiplier"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SprintLabel" Grid.Column="1"
                                       Text="3.0x"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="SprintSlider"
                                Minimum="1.5" Maximum="8" Value="3"
                                SmallChange="0.5" LargeChange="1"
                                Foreground="{DynamicResource TextHighlightBrush}"
                                Margin="0,0,0,12"
                                ValueChanged="Sprint_ValueChanged"/>

                        <!-- Mouse look sensitivity -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mouse sensitivity"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MouseSensLabel" Grid.Column="1"
                                       Text="3"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="MouseSensSlider"
                                Minimum="1" Maximum="10" Value="3"
                                SmallChange="1" LargeChange="2"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                Foreground="{DynamicResource TextHighlightBrush}"
                                Margin="0,0,0,16"
                                ValueChanged="MouseSens_ValueChanged"/>

                        <Separator Margin="0,0,0,12" Background="{DynamicResource BorderBrush}"/>

                        <!-- ── Camera ── -->
                        <TextBlock Text="CAMERA"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource IconBrush}"
                                   Margin="0,0,0,8"/>

                        <!-- Scroll zoom step -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Zoom step (% per notch)"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ZoomStepLabel" Grid.Column="1"
                                       Text="10%"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="ZoomStepSlider"
                                Minimum="2" Maximum="40" Value="10"
                                SmallChange="1" LargeChange="5"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                Foreground="{DynamicResource TextHighlightBrush}"
                                Margin="0,0,0,12"
                                ValueChanged="ZoomStep_ValueChanged"/>

                        <!-- Field of view -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Field of view (°)"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FovLabel" Grid.Column="1"
                                       Text="45°"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       FontSize="11" HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="FovSlider"
                                Minimum="20" Maximum="110" Value="45"
                                SmallChange="1" LargeChange="10"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                Foreground="{DynamicResource TextHighlightBrush}"
                                Margin="0,0,0,8"
                                ValueChanged="Fov_ValueChanged"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── Footer: Reset + Apply + Close ── -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="12,8">
                    <Grid>
                        <Button x:Name="ResetButton"
                                Content="Reset to defaults"
                                HorizontalAlignment="Left"
                                Width="130" Height="32"
                                Margin="0,0,0,0"
                                Style="{StaticResource CustomActionButtonStyle}"
                                FontSize="11"
                                Click="Reset_Click"/>
                        <StackPanel HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button x:Name="ApplyButton"
                                    Content="Apply"
                                    Width="70" Height="32"
                                    Margin="0,0,6,0"
                                    Style="{StaticResource CustomActionButtonStyle}"
                                    FontSize="11"
                                    Click="Apply_Click"/>
                            <Button x:Name="CloseButtonFooter"
                                    Content="Close"
                                    Width="70" Height="32"
                                    Margin="0,0,0,0"
                                    Style="{StaticResource CustomActionButtonStyle}"
                                    FontSize="11"
                                    Click="Close_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
